# Copy this file to `.env` and fill in your own values.
# The .env file is git-ignored so your secrets stay out of version control.
# (Requires the optional `python-dotenv` dependency to be auto-loaded.)

# --- general settings ---
JARVIS_WAKE_WORD=jarvis
JARVIS_CITY=gorakhpur
JARVIS_USERNAME=sir
# The name the assistant refers to itself as
JARVIS_ASSISTANT_NAME=Jarvis
# Require the wake word before acting on a command (1) or not (0)
JARVIS_REQUIRE_WAKE_WORD=0
# Run the startup greeting/weather/calendar sequence (1) or skip it (0)
JARVIS_INIT_SEQUENCE=1
# Override the assets directory (defaults to <project>/assets)
# JARVIS_ASSETS=/absolute/path/to/assets

# --- API credentials ---
# OpenWeatherMap API key: https://openweathermap.org/api
OWM_API_KEY=
# Wolfram Alpha app id: https://developer.wolframalpha.com/
WOLFRAM_APP_ID=

# --- google calendar ---
# Paths to your OAuth client secrets and cached token
# GOOGLE_CREDENTIALS_FILE=/absolute/path/to/credentials.json
# GOOGLE_TOKEN_FILE=/absolute/path/to/token.pickle

# --- premium voice for the web HUD (optional) ---
# Set ONE of these to give the HUD a rich cloud voice (a stock British male
# preset by default). With neither set, the HUD uses the browser's voice.
#
# ElevenLabs (best British male presets): https://elevenlabs.io
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9   # stock "Daniel" (British male); change to any stock voice id
# ELEVENLABS_MODEL=eleven_turbo_v2_5
#
# OpenAI TTS (this project already uses OpenAI): https://platform.openai.com
# OPENAI_API_KEY=
# OPENAI_TTS_VOICE=onyx                        # deep, calm male preset
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
